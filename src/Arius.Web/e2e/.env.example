# Copy to e2e/.env (gitignored) or export these before `npm run e2e`.
# Used by e2e/support/global-setup.ts to seed a repository when the app DB is empty.
ARIUS_E2E_ACCOUNT=ariusciuse
ARIUS_E2E_KEY=<storage-account-key>
ARIUS_E2E_CONTAINER=testexplorer
ARIUS_E2E_PASSPHRASE=<repo-passphrase>
ARIUS_E2E_TIER=hot
ARIUS_E2E_ALIAS=Test Explorer
