# @angular/build 21.2.x declares a peerOptional on vitest ^4, but this project pins vitest 3.
# The pin is deliberate (the specs target vitest 3); the peer is optional and unused. npm 11
# tolerates this, but the npm 10 that ships with CI's Node 22 rejects it during `npm ci`
# (ERESOLVE). legacy-peer-deps makes install/ci ignore the optional-peer conflict on every npm
# version, so local and CI resolve the committed lockfile identically.
legacy-peer-deps=true
